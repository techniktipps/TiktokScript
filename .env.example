# TikTok Konfiguration
TIKTOK_USERNAME=username_here   # Der TikTok-Benutzername (ohne @) dessen Videos gepostet werden sollen

# Supabase Konfiguration (PostgreSQL)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# YouTube API Konfiguration
YOUTUBE_CLIENT_ID=your-oauth2-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-oauth2-client-secret
YOUTUBE_REFRESH_TOKEN=your-oauth2-refresh-token

# Instagram instagrapi Konfiguration
# Einmalig generiert durch das Skript: generate_ig_session.py
INSTAGRAM_SESSION={"cookie": "...", "device_settings": "..."}
